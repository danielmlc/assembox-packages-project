{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/template",
  "sourceRoot": "apps/template/src",
  "compilerOptions": {
    "webpack": true,
    "watchAssets": true,
    "deleteOutDir": false
  },
  "projects": {
    "template": {
      "type": "application",
      "root": "apps/template",
      "entryFile": "main",
      "sourceRoot": "apps/template/src",
      "compilerOptions": {
        "tsConfigPath": "apps/template/tsconfig.json"
      }
    },
    "nest-cloud": {
      "type": "library",
      "root": "libs/nest-cloud",
      "entryFile": "index",
      "sourceRoot": "libs/nest-cloud/src",
      "compilerOptions": {
        "tsConfigPath": "libs/nest-cloud/tsconfig.json"
      }
    },
    "nest-common": {
      "type": "library",
      "root": "libs/nest-common",
      "entryFile": "index",
      "sourceRoot": "libs/nest-common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/nest-common/tsconfig.json"
      }
    },
     "nest-mq": {
      "type": "library",
      "root": "libs/nest-mq",
      "entryFile": "index",
      "sourceRoot": "libs/nest-mq/src",
      "compilerOptions": {
        "tsConfigPath": "libs/nest-mq/tsconfig.json"
      }
    },
      "nest-sms": {
      "type": "library",
      "root": "libs/nest-sms",
      "entryFile": "index",
      "sourceRoot": "libs/nest-sms/src",
      "compilerOptions": {
        "tsConfigPath": "libs/nest-sms/tsconfig.json"
      }
    },
      "nest-mail": {
      "type": "library",
      "root": "libs/nest-mail",
      "entryFile": "index",
      "sourceRoot": "libs/nest-mail/src",
      "compilerOptions": {
        "tsConfigPath": "libs/nest-mail/tsconfig.json"
      }
    },
    "nest-config": {
      "type": "library",
      "root": "libs/nest-config",
      "entryFile": "index",
      "sourceRoot": "libs/nest-config/src",
      "compilerOptions": {
        "tsConfigPath": "libs/nest-config/tsconfig.json"
      }
    },
    "sdk": {
      "type": "application",
      "root": "apps/sdk",
      "entryFile": "main",
      "sourceRoot": "apps/sdk/src",
      "compilerOptions": {
        "tsConfigPath": "apps/sdk/tsconfig.json"
      }
    },
    "cas-demo": {
      "type": "application",
      "root": "apps/cas-demo",
      "entryFile": "main",
      "sourceRoot": "apps/cas-demo/src",
      "compilerOptions": {
        "tsConfigPath": "apps/cas-demo/tsconfig.json"
      }
    },
    "cas-inner-demo": {
      "type": "application",
      "root": "apps/cas-inner-demo",
      "entryFile": "main",
      "sourceRoot": "apps/cas-inner-demo/src",
      "compilerOptions": {
        "tsConfigPath": "apps/cas-inner-demo/tsconfig.json"
      }
    },
    "nest-redis": {
      "type": "library",
      "root": "libs/nest-redis",
      "entryFile": "index",
      "sourceRoot": "libs/nest-redis/src",
      "compilerOptions": {
        "tsConfigPath": "libs/nest-redis/tsconfig.json"
      }
    },
    "nest-cas-client": {
      "type": "library",
      "root": "libs/nest-cas-client",
      "entryFile": "index",
      "sourceRoot": "libs/nest-cas-client/src",
      "compilerOptions": {
        "tsConfigPath": "libs/nest-cas-client/tsconfig.json"
      }
    },
    "nest-auth-client": {
      "type": "library",
      "root": "libs/nest-auth-client",
      "entryFile": "index",
      "sourceRoot": "libs/nest-auth-client/src",
      "compilerOptions": {
        "tsConfigPath": "libs/nest-auth-client/tsconfig.json"
      }
    },
    "nest-files": {
      "type": "library",
      "root": "libs/nest-files",
      "entryFile": "index",
      "sourceRoot": "libs/nest-files/src",
      "compilerOptions": {
        "tsConfigPath": "libs/nest-files/tsconfig.json"
      }
    },
    "nest-orm-mysql": {
      "type": "library",
      "root": "libs/nest-orm-mysql",
      "entryFile": "index",
      "sourceRoot": "libs/nest-orm-mysql/src",
      "compilerOptions": {
        "tsConfigPath": "libs/nest-orm-mysql/tsconfig.json"
      }
    },
    "node-pf-protal-service": {
      "type": "application",
      "root": "apps/node-pf-protal-service",
      "entryFile": "main",
      "sourceRoot": "apps/node-pf-protal-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/node-pf-protal-service/tsconfig.app.json"
      }
    }
  }
}
