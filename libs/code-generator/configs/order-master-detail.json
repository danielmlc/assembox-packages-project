{
  "moduleName": "订单管理模块",
  "moduleCode": "order",
  "connectionName": "default",
  "entities": [
    {
      "entityName": "订单主表",
      "entityCode": "order",
      "tableName": "orders",
      "generateService": true,
      "generateController": true,
      "fields": [
        {
          "fieldName": "订单ID",
          "fieldCode": "id",
          "fieldType": "bigint",
          "primaryKey": true,
          "required": true,
          "nullable": false
        },
        {
          "fieldName": "订单编号",
          "fieldCode": "order_no",
          "fieldType": "string",
          "length": 50,
          "required": true,
          "nullable": false
        },
        {
          "fieldName": "客户ID",
          "fieldCode": "customer_id",
          "fieldType": "bigint",
          "required": true,
          "nullable": false
        },
        {
          "fieldName": "订单状态",
          "fieldCode": "status",
          "fieldType": "string",
          "length": 20,
          "required": true,
          "nullable": false,
          "defaultValue": "pending",
          "comment": "pending-待处理/confirmed-已确认/shipped-已发货/completed-已完成/cancelled-已取消"
        },
        {
          "fieldName": "订单总金额",
          "fieldCode": "total_amount",
          "fieldType": "decimal",
          "precision": 10,
          "scale": 2,
          "required": true,
          "nullable": false,
          "defaultValue": "0"
        },
        {
          "fieldName": "创建时间",
          "fieldCode": "created_at",
          "fieldType": "datetime",
          "required": false,
          "nullable": true
        },
        {
          "fieldName": "备注",
          "fieldCode": "remark",
          "fieldType": "string",
          "length": 500,
          "required": false,
          "nullable": true
        }
      ],
      "serviceMethods": [
        {
          "methodName": "createOrderWithDetails",
          "description": "创建订单（主表+明细表，带事务）",
          "async": true,
          "parameters": [
            {
              "name": "orderData",
              "type": "CreateOrderDto",
              "optional": false,
              "description": "订单主表数据"
            },
            {
              "name": "detailsData",
              "type": "CreateOrderDetailDto[]",
              "optional": false,
              "description": "订单明细数据"
            }
          ],
          "returnType": "Order",
          "steps": [
            {
              "type": "log",
              "comment": "记录开始创建订单",
              "config": {
                "level": "info",
                "message": { "expr": "`开始创建订单，明细数量: ${detailsData.length}`" }
              }
            },
            {
              "type": "declare",
              "comment": "声明事务查询运行器",
              "config": {
                "name": "queryRunner",
                "type": "any",
                "const": true,
                "initialValue": {
                  "expr": "this.orderRepository.manager.connection.createQueryRunner()"
                }
              }
            },
            {
              "type": "validate",
              "comment": "验证明细数据",
              "config": {
                "rules": [
                  {
                    "condition": { "expr": "detailsData && detailsData.length > 0" },
                    "message": "订单明细不能为空",
                    "exceptionType": "BadRequest"
                  }
                ]
              }
            },
            {
              "type": "save",
              "comment": "保存订单主表",
              "config": {
                "result": "order",
                "data": {
                  "type": "param",
                  "name": "orderData"
                }
              }
            },
            {
              "type": "log",
              "config": {
                "level": "info",
                "message": { "expr": "`订单主表已创建，订单ID: ${order.id}`" }
              }
            },
            {
              "type": "return",
              "config": {
                "value": { "expr": "order" }
              }
            }
          ]
        },
        {
          "methodName": "confirmOrder",
          "description": "确认订单（调用库存服务，带事务）",
          "async": true,
          "parameters": [
            {
              "name": "orderId",
              "type": "string",
              "optional": false,
              "description": "订单ID"
            }
          ],
          "returnType": "Order",
          "steps": [
            {
              "type": "queryOne",
              "comment": "查询订单",
              "config": {
                "result": "order",
                "where": [
                  {
                    "field": "id",
                    "operator": "eq",
                    "value": { "expr": "orderId" }
                  }
                ],
                "notFoundBehavior": "throw",
                "notFoundMessage": "订单不存在"
              }
            },
            {
              "type": "validate",
              "comment": "验证订单状态",
              "config": {
                "rules": [
                  {
                    "condition": { "expr": "order.status === 'pending'" },
                    "message": "只有待处理的订单可以确认",
                    "exceptionType": "BadRequest"
                  }
                ]
              }
            },
            {
              "type": "log",
              "comment": "调用库存服务锁定库存",
              "config": {
                "level": "info",
                "message": { "expr": "`调用库存服务锁定库存，订单ID: ${orderId}`" }
              }
            },
            {
              "type": "update",
              "comment": "更新订单状态为已确认",
              "config": {
                "where": [
                  {
                    "field": "id",
                    "operator": "eq",
                    "value": { "expr": "orderId" }
                  }
                ],
                "data": {
                  "type": "build",
                  "fields": [
                    {
                      "field": "status",
                      "value": { "literal": "confirmed" }
                    }
                  ]
                }
              }
            },
            {
              "type": "log",
              "config": {
                "level": "info",
                "message": { "expr": "`订单 ${orderId} 已确认`" }
              }
            },
            {
              "type": "queryOne",
              "comment": "返回更新后的订单",
              "config": {
                "result": "updatedOrder",
                "where": [
                  {
                    "field": "id",
                    "operator": "eq",
                    "value": { "expr": "orderId" }
                  }
                ]
              }
            },
            {
              "type": "return",
              "config": {
                "value": { "expr": "updatedOrder" }
              }
            }
          ]
        },
        {
          "methodName": "calculateOrderAmount",
          "description": "计算订单总金额（从明细表汇总）",
          "async": true,
          "parameters": [
            {
              "name": "orderId",
              "type": "string",
              "optional": false,
              "description": "订单ID"
            }
          ],
          "returnType": "number",
          "steps": [
            {
              "type": "log",
              "comment": "记录计算日志",
              "config": {
                "level": "debug",
                "message": { "expr": "`计算订单总金额，订单ID: ${orderId}`" }
              }
            },
            {
              "type": "declare",
              "comment": "调用明细服务查询明细",
              "config": {
                "name": "details",
                "type": "any[]",
                "const": true,
                "initialValue": { "expr": "[]" }
              }
            },
            {
              "type": "declare",
              "comment": "计算总金额",
              "config": {
                "name": "totalAmount",
                "type": "number",
                "const": true,
                "initialValue": {
                  "expr": "details.reduce((sum, detail) => sum + (detail.quantity * detail.price), 0)"
                }
              }
            },
            {
              "type": "log",
              "config": {
                "level": "info",
                "message": { "expr": "`订单 ${orderId} 总金额: ${totalAmount}`" }
              }
            },
            {
              "type": "return",
              "config": {
                "value": { "expr": "totalAmount" }
              }
            }
          ]
        },
        {
          "methodName": "shipOrder",
          "description": "发货订单（更新状态、调用物流服务）",
          "async": true,
          "parameters": [
            {
              "name": "orderId",
              "type": "string",
              "optional": false,
              "description": "订单ID"
            },
            {
              "name": "trackingNumber",
              "type": "string",
              "optional": false,
              "description": "物流单号"
            }
          ],
          "returnType": "Order",
          "steps": [
            {
              "type": "queryOne",
              "comment": "查询订单",
              "config": {
                "result": "order",
                "where": [
                  {
                    "field": "id",
                    "operator": "eq",
                    "value": { "expr": "orderId" }
                  }
                ],
                "notFoundBehavior": "throw",
                "notFoundMessage": "订单不存在"
              }
            },
            {
              "type": "validate",
              "comment": "验证订单状态",
              "config": {
                "rules": [
                  {
                    "condition": { "expr": "order.status === 'confirmed'" },
                    "message": "只有已确认的订单可以发货",
                    "exceptionType": "BadRequest"
                  }
                ]
              }
            },
            {
              "type": "log",
              "comment": "调用物流服务",
              "config": {
                "level": "info",
                "message": { "expr": "`调用物流服务，物流单号: ${trackingNumber}`" }
              }
            },
            {
              "type": "update",
              "comment": "更新订单状态为已发货",
              "config": {
                "where": [
                  {
                    "field": "id",
                    "operator": "eq",
                    "value": { "expr": "orderId" }
                  }
                ],
                "data": {
                  "type": "build",
                  "fields": [
                    {
                      "field": "status",
                      "value": { "literal": "shipped" }
                    }
                  ]
                }
              }
            },
            {
              "type": "queryOne",
              "comment": "返回更新后的订单",
              "config": {
                "result": "shippedOrder",
                "where": [
                  {
                    "field": "id",
                    "operator": "eq",
                    "value": { "expr": "orderId" }
                  }
                ]
              }
            },
            {
              "type": "return",
              "config": {
                "value": { "expr": "shippedOrder" }
              }
            }
          ]
        }
      ]
    },
    {
      "entityName": "订单明细表",
      "entityCode": "order_detail",
      "tableName": "order_details",
      "generateService": true,
      "generateController": true,
      "fields": [
        {
          "fieldName": "明细ID",
          "fieldCode": "id",
          "fieldType": "bigint",
          "primaryKey": true,
          "required": true,
          "nullable": false
        },
        {
          "fieldName": "订单ID",
          "fieldCode": "order_id",
          "fieldType": "bigint",
          "required": true,
          "nullable": false
        },
        {
          "fieldName": "商品ID",
          "fieldCode": "product_id",
          "fieldType": "bigint",
          "required": true,
          "nullable": false
        },
        {
          "fieldName": "商品名称",
          "fieldCode": "product_name",
          "fieldType": "string",
          "length": 200,
          "required": true,
          "nullable": false
        },
        {
          "fieldName": "数量",
          "fieldCode": "quantity",
          "fieldType": "int",
          "required": true,
          "nullable": false
        },
        {
          "fieldName": "单价",
          "fieldCode": "price",
          "fieldType": "decimal",
          "precision": 10,
          "scale": 2,
          "required": true,
          "nullable": false
        },
        {
          "fieldName": "小计",
          "fieldCode": "subtotal",
          "fieldType": "decimal",
          "precision": 10,
          "scale": 2,
          "required": true,
          "nullable": false
        }
      ],
      "serviceMethods": [
        {
          "methodName": "findByOrderId",
          "description": "根据订单ID查询明细列表",
          "async": true,
          "parameters": [
            {
              "name": "orderId",
              "type": "string",
              "optional": false,
              "description": "订单ID"
            }
          ],
          "returnType": "OrderDetail[]",
          "steps": [
            {
              "type": "log",
              "config": {
                "level": "debug",
                "message": { "expr": "`查询订单明细，订单ID: ${orderId}`" }
              }
            },
            {
              "type": "query",
              "config": {
                "result": "details",
                "where": [
                  {
                    "field": "orderId",
                    "operator": "eq",
                    "value": { "expr": "orderId" }
                  }
                ]
              }
            },
            {
              "type": "return",
              "config": {
                "value": { "expr": "details" }
              }
            }
          ]
        },
        {
          "methodName": "batchCreate",
          "description": "批量创建订单明细",
          "async": true,
          "parameters": [
            {
              "name": "detailsData",
              "type": "CreateOrderDetailDto[]",
              "optional": false,
              "description": "明细数据列表"
            }
          ],
          "returnType": "OrderDetail[]",
          "steps": [
            {
              "type": "log",
              "config": {
                "level": "info",
                "message": { "expr": "`批量创建订单明细，数量: ${detailsData.length}`" }
              }
            },
            {
              "type": "declare",
              "comment": "创建实体列表",
              "config": {
                "name": "entities",
                "type": "any[]",
                "const": true,
                "initialValue": {
                  "expr": "detailsData.map(data => this.orderDetailRepository.create(data))"
                }
              }
            },
            {
              "type": "declare",
              "comment": "批量保存",
              "config": {
                "name": "savedDetails",
                "type": "any[]",
                "const": true,
                "initialValue": { "expr": "await this.orderDetailRepository.save(entities)" }
              }
            },
            {
              "type": "return",
              "config": {
                "value": { "expr": "savedDetails" }
              }
            }
          ]
        }
      ]
    }
  ]
}
